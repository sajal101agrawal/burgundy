{
  "name": "concierge-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @concierge/db migrate",
    "db:generate": "pnpm --filter @concierge/db generate"
  },
  "devDependencies": {
    "turbo": "^2.0.5",
    "typescript": "^5.5.4"
  }
}
