{
  "name": "concierge-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:up": "./scripts/dev-up.sh",
    "lint": "turbo run lint --filter=!openclaw --filter=!openclaw-control-ui",
    "lint:upstream": "turbo run lint --filter=openclaw --filter=openclaw-control-ui",
    "typecheck": "turbo run typecheck --filter=!openclaw --filter=!openclaw-control-ui",
    "typecheck:upstream": "turbo run typecheck --filter=openclaw --filter=openclaw-control-ui",
    "node:start": "./scripts/node-start.sh",
    "smoke": "./scripts/smoke.sh",
    "db:migrate": "pnpm --filter @concierge/db migrate",
    "db:generate": "pnpm --filter @concierge/db generate"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "turbo": "^2.0.5",
    "typescript": "^5.5.4"
  }
}
